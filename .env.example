#Database
DATABASE_URL=

#Server
PORT=3001

#Telegram
TELEGRAM_BOT_TOKEN=

# Mini-app public URL(s) for CORS (required on Railway in production)
# Local: http://localhost:3000
# Railway: https://your-mini-app.up.railway.app
# Multiple origins: https://app1.up.railway.app,https://app2.up.railway.app
MINI_APP_ORIGIN=

#Crypto Pay (@send — https://t.me/send → /pay)
CRYPTOBOT_KEY=

#Apay site verification (meta tag on GET /)
APAY_VERIFICATION_TAG=

#Redis
REDIS_URL=redis://:password@127.0.0.1:6379

#AI Providers
OPENROUTER_API_KEY=
SHARPII_API_KEY=
SHARPII_API_URL=https://api.sharpii.ai
# Sharpii covers Midjourney/Sora/Seedance
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_DUBBING_TARGET_LANG=ru
# Sound effects (Генерация звуков)
ELEVENLABS_SFX_MODEL_ID=eleven_text_to_sound_v2
ELEVENLABS_SFX_PROMPT_INFLUENCE=0.75
ELEVENLABS_SFX_DURATION_SECONDS=5
# Cached voice preview files (Railway volume: /app/storage/voice-previews)
VOICE_PREVIEWS_DIR=/app/storage/voice-previews
# Optional override (default: https://api.elevenlabs.io/v1)
# ELEVENLABS_BASE_URL=https://api.elevenlabs.io/v1
HEYGEN_API_KEY=
# Optional: look id from GET /v3/avatars/looks (if auto-pick fails)
HEYGEN_AVATAR_ID=
HEYGEN_VOICE_ID=
HIGGSFIELD_API_KEY=
TOPAZ_API_KEY=
