generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

enum SubscribeType {
  FREE
  LITE
  PRO
  BUSINESS
  NOT_SUBSCRIBED
}

enum SubscribePlan {
  MONTHLY
  THREE_MONTHS
  SIX_MONTHS
  YEARLY
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum UserLanguage {
  RU
  EN
}

enum PaymentStatus {
  PENDING
  PAID
  EXPIRED
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id        String   @id @default(uuid())
  password  String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admins")
}

model User {
  id        String   @id @default(uuid())

  telegramId String   @unique
  telegramUsername String?
  lastActivityAt DateTime?

  subscribeType SubscribeType @default(NOT_SUBSCRIBED)
  lastSubscriptionType SubscribeType?
  subscribePlan SubscribePlan?
  subscriptionStartsAt DateTime?
  subscriptionEndsAt DateTime?
  lastTokenIssueAt DateTime? 
  useFreeSub Boolean @default(false)
  isSubscriptionActive Boolean @default(false)

  tokenLeft Int @default(0)
  language UserLanguage @default(RU)

  nextSubscription NextSubscriptionOfUser?
  aiGenerationJobs AiGenerationJob[]
  payments Payment[]
  gptConversations GptConversation[]
  aiToolSettings UserAiToolSettings[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model ElevenLabsVoicePreview {
  id         String   @id @default(uuid())
  voiceId    String
  localeTag  String
  filePath   String
  sampleText String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([voiceId, localeTag])
  @@map("elevenlabs_voice_previews")
}

model UserAiToolSettings {
  id       String @id @default(uuid())
  userId   String
  toolId   String
  settings Json
  user     User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, toolId])
  @@map("user_ai_tool_settings")
}

model Payment {
  id                 String        @id @default(uuid())
  userId             String
  user               User          @relation(fields: [userId], references: [id])
  cryptoPayInvoiceId BigInt        @unique
  subscribeType      SubscribeType
  subscribePlan      SubscribePlan
  amountUsd          String
  status             PaymentStatus @default(PENDING)
  payload            String        @unique
  paidAt             DateTime?
  createdAt          DateTime      @default(now())

  @@map("payments")
}

model NextSubscriptionOfUser {
  id String @id @default(uuid())

  user User @relation(fields: [userId], references: [id])
  userId String @unique
  subType SubscribeType
  subPlan SubscribePlan
  subscriptionEndsAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("next_subscription_of_users")
}

model AiGenerationJob {
  id            String    @id @default(uuid())
  userId        String
  toolId        String
  providerJobId String?
  status        JobStatus @default(PENDING)
  tokenCost     Int
  inputJson     Json
  resultUrl     String?
  errorMessage  String?
  pollAttempts  Int       @default(0)
  pollErrorCount Int      @default(0)
  lastPolledAt  DateTime?
  staleReminderSent Boolean @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([status, createdAt])
  @@map("ai_generation_jobs")
}

model GptConversation {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  messages  GptMessage[]

  @@index([userId, updatedAt])
  @@map("gpt_conversations")
}

model GptMessage {
  id             String          @id @default(uuid())
  conversationId String
  conversation   GptConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String          @db.Text
  createdAt      DateTime        @default(now())

  @@index([conversationId, createdAt])
  @@map("gpt_messages")
}